# Short-Circuit Calculator - Environment Variables

# Application
APP_NAME="Short-Circuit Calculator"
APP_VERSION="1.0.0"
DEBUG=false

# Database
DATABASE_URL="sqlite:///./short_circuit.db"

# Authentication
SECRET_KEY="change-this-to-a-secure-random-string-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM="HS256"

# CORS origins (comma-separated)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
