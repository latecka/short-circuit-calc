{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://short-circuit-calc/schemas/line.json",
  "title": "Line",
  "description": "Overhead line or cable element",
  "type": "object",
  "required": ["id", "type", "bus_from", "bus_to", "length", "r1_per_km", "x1_per_km", "r0_per_km", "x0_per_km"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier"
    },
    "type": {
      "enum": ["overhead_line", "cable"]
    },
    "name": {
      "type": ["string", "null"],
      "description": "Descriptive name"
    },
    "bus_from": {
      "type": "string",
      "description": "From busbar ID"
    },
    "bus_to": {
      "type": "string",
      "description": "To busbar ID"
    },
    "length": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Line length [km]"
    },
    "r1_per_km": {
      "type": "number",
      "minimum": 0,
      "description": "Positive sequence resistance [ohm/km]"
    },
    "x1_per_km": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Positive sequence reactance [ohm/km]"
    },
    "r0_per_km": {
      "type": "number",
      "minimum": 0,
      "description": "Zero sequence resistance [ohm/km]"
    },
    "x0_per_km": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Zero sequence reactance [ohm/km]"
    },
    "b1_per_km": {
      "type": "number",
      "minimum": 0,
      "default": 0,
      "description": "Positive sequence susceptance [uS/km]"
    },
    "parallel_lines": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Number of parallel lines"
    },
    "cable_type": {
      "type": ["string", "null"],
      "description": "Cable type designation (cables only)"
    },
    "in_service": {
      "type": "boolean",
      "default": true,
      "description": "Element in service"
    }
  },
  "additionalProperties": false
}
