{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://short-circuit-calc/schemas/impedance.json",
  "title": "Impedance Element",
  "description": "General impedance element",
  "type": "object",
  "required": ["id", "type", "bus_from", "bus_to", "R", "X"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier"
    },
    "type": {
      "const": "impedance"
    },
    "name": {
      "type": ["string", "null"],
      "description": "Descriptive name"
    },
    "bus_from": {
      "type": "string",
      "description": "From busbar ID"
    },
    "bus_to": {
      "type": "string",
      "description": "To busbar ID"
    },
    "R": {
      "type": "number",
      "minimum": 0,
      "description": "Resistance [ohm]"
    },
    "X": {
      "type": "number",
      "description": "Reactance [ohm]"
    },
    "R0": {
      "type": ["number", "null"],
      "minimum": 0,
      "description": "Zero sequence resistance [ohm] - defaults to R"
    },
    "X0": {
      "type": ["number", "null"],
      "description": "Zero sequence reactance [ohm] - defaults to X"
    },
    "in_service": {
      "type": "boolean",
      "default": true,
      "description": "Element in service"
    }
  },
  "additionalProperties": false
}
